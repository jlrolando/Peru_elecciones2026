#!/usr/bin/env Rscript
# ==============================================================================
# ONPE 2026 — District-Level Presidential Results
# Pulls votes for 5 candidates + % actas contabilizadas for every district
#
# BEFORE RUNNING:
#   install.packages(c("httr", "jsonlite", "dplyr", "readr"))
#
# UBIGEO SOURCE:
#   Download the CSV from: https://github.com/geodir/ubigeo-peru
#   Direct link to raw CSV:
#     https://raw.githubusercontent.com/geodir/ubigeo-peru/master/geodir-ubigeo-inei.csv
#   Save it as "geodir-ubigeo-inei.csv" in your working directory.
#
# IMPORTANT — RENIEC vs INEI ubigeo codes:
#   ONPE historically uses RENIEC ubigeo codes, which CAN differ from INEI
#   codes for some districts. In our testing, the ONPE API accepted INEI codes
#   (e.g., 010101 for Chachapoyas). If you get empty results for specific
#   districts, the code mismatch is the likely cause. A RENIEC-INEI concordance
#   table is available at: https://github.com/CONCYTEC/ubigeo-peru
#
# RUNTIME ESTIMATE:
#   ~1,874 districts × 2 API calls × 0.5s delay ≈ 30 minutes
# ==============================================================================

library(httr)
library(jsonlite)
library(dplyr)
library(readr)

setwd("C:/Users/jlrolando/UFL Dropbox/Jose Luis Rolando Betancourt/elecciones2026/")

# --- Log to file --------------------------------------------------------------
options(cli.num_colors = 0)
options(crayon.enabled = FALSE)
options(cli.unicode = FALSE)
options(readr.show_progress = FALSE)

LOG_FILE <- "onpe_extrapolation_output_1033.txt"
writeLines("", LOG_FILE)

msg <- function(...) {
  txt <- paste0(...)
  
  # 1. Print to the RStudio Console
  cat(txt, "\n") 
  
  # 2. Prepare clean text for the file
  clean <- gsub("\033\\[[0-9;]*[A-Za-z]", "", txt)
  clean <- gsub("[^[:print:]\n\t]", "", clean)
  
  # 3. Force write to the file immediately
  con <- file(LOG_FILE, open = "a")
  writeLines(clean, con)
  close(con) # Closing the connection forces R to save the file to disk
}


# --- 1. Load ubigeo table ----------------------------------------------------
# Rationale: the geodir CSV has columns Ubigeo (6-digit INEI code), Distrito,
# Provincia, Departamento. We derive dept and province codes by zero-padding.

ubigeo_raw <- read_csv("geodir-ubigeo-reniec.csv", col_types = cols(.default = "c"))

ubigeo <- ubigeo_raw %>%
  transmute(
    dist_code = Ubigeo,                                    # e.g., "010101"
    dept_code = paste0(substr(Ubigeo, 1, 2), "0000"),      # e.g., "010000"
    prov_code = paste0(substr(Ubigeo, 1, 4), "00"),        # e.g., "010100"
    departamento = Departamento,
    provincia    = Provincia,
    distrito     = Distrito
  )

message("Loaded ", nrow(ubigeo), " districts")

# --- 2. API configuration ----------------------------------------------------

BASE <- "https://resultadoelectoral.onpe.gob.pe/presentacion-backend"
VOTES_EP <- paste0(BASE, "/eleccion-presidencial/participantes-ubicacion-geografica-nombre")
ACTAS_EP <- paste0(BASE, "/resumen-general/totales")

# Candidates of interest — names exactly as they appear in the ONPE API
# Rationale: the API returns full uppercase names. We match on these strings
# and use short labels for the output columns.
CANDIDATES <- c(
  "Fujimori"     = "KEIKO SOFIA FUJIMORI HIGUCHI",
  "Lopez_Aliaga" = "RAFAEL BERNARDO L\u00d3PEZ ALIAGA CAZORLA",
  "Nieto"        = "JORGE NIETO MONTESINOS",
  "Belmont"      = "RICARDO PABLO BELMONT CASSINELLI",
  "Sanchez"      = "ROBERTO HELBERT SANCHEZ PALOMINO"
)

# NOTE on accent marks: The API may return "LÓPEZ" (with accent) or "LOPEZ"
# (without). If matching fails, run one test query and inspect the exact
# spelling:
#   test_url <- paste0(VOTES_EP, "?tipoFiltro=ubigeo_nivel_03",
#     "&idAmbitoGeografico=1&ubigeoNivel1=010000&ubigeoNivel2=010100",
#     "&ubigeoNivel3=010101&idEleccion=10")
#   fromJSON(content(GET(test_url), "text"))$data$nombreCandidato

# --- 3. Fetch helper with retries --------------------------------------------
# Rationale: transient errors (timeouts, 429s) are expected when hitting the
# ONPE server ~3,700 times. We retry 3× with exponential backoff.

safe_GET <- function(url, params, retries = 1) {
  for (i in seq_len(retries)) {
    resp <- tryCatch(
      GET(url, query = params, timeout(10),
          add_headers(
            `User-Agent` = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36",
            `Referer` = "https://resultadoelectoral.onpe.gob.pe/main/presidenciales",
            `Accept` = "application/json"
          )
      ),
      error = function(e) NULL
    )
    if (!is.null(resp) && status_code(resp) == 200) {
      txt <- content(resp, as = "text", encoding = "UTF-8")
      if (startsWith(trimws(txt), "{")) {
        return(txt)
      }
    }
    Sys.sleep(i * 2)
  }
  return(NA_character_)
}

# --- 4. Query one district ----------------------------------------------------

query_district <- function(dept, prov, dist) {
  
  # 4a. Actas contabilizadas
  actas_json <- safe_GET(ACTAS_EP, list(
    idAmbitoGeografico   = 1,
    idEleccion           = 10,
    tipoFiltro           = "ubigeo_nivel_03",
    idUbigeoDepartamento = dept,
    idUbigeoProvincia    = prov,
    idUbigeoDistrito     = dist
  ))
  if (is.na(actas_json)) return(NULL)
  actas <- fromJSON(actas_json)
  if (!actas$success) return(NULL)
  
  # 4b. Votes per candidate
  votes_json <- safe_GET(VOTES_EP, list(
    tipoFiltro         = "ubigeo_nivel_03",
    idAmbitoGeografico = 1,
    ubigeoNivel1       = dept,
    ubigeoNivel2       = prov,
    ubigeoNivel3       = dist,
    idEleccion         = 10
  ))
  if (is.na(votes_json)) return(NULL)
  votes <- fromJSON(votes_json)
  if (!votes$success || length(votes$data) == 0) return(NULL)
  
  # 4c. Build one-row result
  row <- tibble(
    dist_ubigeo          = dist,
    pct_actas            = actas$data$actasContabilizadas,
    actas_contabilizadas = actas$data$contabilizadas,
    total_actas          = actas$data$totalActas
  )
  
  # Extract each candidate's votes
  cands <- votes$data
  for (short in names(CANDIDATES)) {
    full_name <- CANDIDATES[short]
    match <- cands[cands$nombreCandidato == full_name, ]
    if (nrow(match) == 1) {
      row[[paste0("votos_", short)]] <- match$totalVotosValidos
      row[[paste0("pct_", short)]]   <- match$porcentajeVotosValidos
    } else {
      row[[paste0("votos_", short)]] <- NA_integer_
      row[[paste0("pct_", short)]]   <- NA_real_
    }
  }
  
  return(row)
}

# --- 5. Run across all districts ----------------------------------------------
# Rationale: we use a simple for-loop (not purrr::map) for easier progress
# tracking and error handling. Results are appended to a list, then bound.

results <- vector("list", nrow(ubigeo))

message("Starting queries at ", Sys.time())

for (i in seq_len(nrow(ubigeo))) {
  
  if (i %% 25 == 0 || i == 1) {
    message(sprintf("[%s] District %d / %d — %s, %s, %s",
                    format(Sys.time(), "%H:%M:%S"), i, nrow(ubigeo),
                    ubigeo$departamento[i], ubigeo$provincia[i], ubigeo$distrito[i]))
  }
  
  results[[i]] <- tryCatch(
    query_district(ubigeo$dept_code[i], ubigeo$prov_code[i], ubigeo$dist_code[i]),
    error = function(e) {
      message("  ERROR at row ", i, ": ", e$message)
      NULL
    }
  )
  
  # Polite delay — 0.05s between requests
  Sys.sleep(0.05)
}

# --- 6. Combine and merge with district names ---------------------------------

df <- bind_rows(results)
message("Got data for ", nrow(df), " districts out of ", nrow(ubigeo))

# Merge with ubigeo names
final <- ubigeo %>%
  left_join(df, by = c("dist_code" = "dist_ubigeo"))

# --- 7. Save ------------------------------------------------------------------

write_csv(final, "onpe_2026_district_results_04142026_1033.csv")
message("Saved to onpe_2026_district_results_04142026_1033.csv")

# Quick summary
message("\n=== Summary ===")
message("Districts with data: ", sum(!is.na(final$pct_actas)))
message("Districts missing:   ", sum(is.na(final$pct_actas)))
message("Mean % actas:        ", round(mean(final$pct_actas, na.rm = TRUE), 1), "%")


