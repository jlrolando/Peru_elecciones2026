}

# --- Extrapolate each extranjero unit -----------------------------------------

for (c in candidates) ext_df[[paste0("extrap_", c)]] <- 0
ext_df$method <- ""

for (i in seq_len(nrow(ext_df))) {
  pct  <- ext_df$pct_actas[i]
  ta   <- ext_df$total_actas[i]
  cont <- ext_df$continent[i]
  if (is.na(ta)) ta <- 0
  
  if (!is.na(pct) && pct > 0) {
    for (c in candidates) {
      v <- ext_df[[paste0("votos_", c)]][i]; if (is.na(v)) v <- 0
      ext_df[[paste0("extrap_", c)]][i] <- v * (100 / pct)
    }
    ext_df$method[i] <- "direct"
  } else if (ta > 0 && cont %in% names(continent_avgs)) {
    avg <- continent_avgs[[cont]]
    est_valid <- avg$vpa * ta
    for (c in candidates) ext_df[[paste0("extrap_", c)]][i] <- est_valid * avg$shares[c]
    ext_df$method[i] <- "imputed_continent"
  } else if (ta > 0 && !is.null(global_avg)) {
    est_valid <- global_avg$vpa * ta
    for (c in candidates) ext_df[[paste0("extrap_", c)]][i] <- est_valid * global_avg$shares[c]
    ext_df$method[i] <- "imputed_global"
  } else {
    ext_df$method[i] <- "skipped"
  }
}

