# --- Query one district -------------------------------------------------------

query_district <- function(dept, prov, dist) {
  actas_json <- safe_GET(ACTAS_EP, list(
    idAmbitoGeografico = 1, idEleccion = 10, tipoFiltro = "ubigeo_nivel_03",
    idUbigeoDepartamento = dept, idUbigeoProvincia = prov, idUbigeoDistrito = dist
  ))
  if (is.na(actas_json)) return(NULL)
  actas <- fromJSON(actas_json)
  if (!actas$success) return(NULL)
  
  votes_json <- safe_GET(VOTES_EP, list(
    tipoFiltro = "ubigeo_nivel_03", idAmbitoGeografico = 1,
    ubigeoNivel1 = dept, ubigeoNivel2 = prov, ubigeoNivel3 = dist, idEleccion = 10
  ))
  if (is.na(votes_json)) return(NULL)
  votes <- fromJSON(votes_json)
  if (!votes$success || length(votes$data) == 0) return(NULL)
  
  row <- tibble(
    dist_ubigeo = dist,
    pct_actas = actas$data$actasContabilizadas,
    actas_contabilizadas = actas$data$contabilizadas,
    total_actas = actas$data$totalActas
  )
  
  cands <- votes$data
  for (s in names(CANDIDATES)) {
    match_row <- cands[cands$nombreCandidato == CANDIDATES[s], ]
    if (nrow(match_row) == 1) {
      row[[paste0("votos_", s)]] <- match_row$totalVotosValidos
      row[[paste0("pct_", s)]]   <- match_row$porcentajeVotosValidos
    } else {
      row[[paste0("votos_", s)]] <- NA_integer_
      row[[paste0("pct_", s)]]   <- NA_real_
    }
  }
  return(row)
}

