#!/usr/bin/env Rscript
# ==============================================================================
# ONPE 2026 — Full Extrapolation: Domestic Districts + Extranjero by Continent
#
# Logic:
#   DOMESTIC:
#     1. Districts with actas > 0 → direct extrapolation
#     2. Districts with 0 actas → impute from province (excl. big cities),
#        falling back to department
#   EXTRANJERO:
#     1. Fetch votes + actas per continent from ONPE API
#     2. Continents with actas > 0 → direct extrapolation
#     3. Continents with 0 actas (e.g., Africa) → impute from average of
#        other continents
#
# REQUIRES:
#   - onpe_2026_district_results_04132026_2323.csv in working directory
#   - Internet connection (to fetch extranjero)
#   - install.packages(c("httr", "jsonlite", "readr"))
#
# OUTPUT:
#   - onpe_2026_extrapolated_full.csv
#   - onpe_extrapolation_output.txt
# ==============================================================================

# --- API config ---------------------------------------------------------------

BASE <- "https://resultadoelectoral.onpe.gob.pe/presentacion-backend"
VOTES_EP <- paste0(BASE, "/eleccion-presidencial/participantes-ubicacion-geografica-nombre")
ACTAS_EP <- paste0(BASE, "/resumen-general/totales")

CAND_FULLNAMES <- c(
  Fujimori     = "KEIKO SOFIA FUJIMORI HIGUCHI",
  Lopez_Aliaga = "RAFAEL BERNARDO L\u00d3PEZ ALIAGA CAZORLA",
  Nieto        = "JORGE NIETO MONTESINOS",
  Belmont      = "RICARDO PABLO BELMONT CASSINELLI",
  Sanchez      = "ROBERTO HELBERT SANCHEZ PALOMINO"
)

candidates <- names(CAND_FULLNAMES)

labels <- c(
  Fujimori     = "Keiko Fujimori (Fuerza Popular)",
  Lopez_Aliaga = "Rafael Lopez Aliaga (Renovacion Popular)",
  Nieto        = "Jorge Nieto (Buen Gobierno)",
  Belmont      = "Ricardo Belmont (Civico Obras)",
  Sanchez      = "Roberto Sanchez (Juntos por el Peru)"
)

short <- c(Fujimori = "FUJ", Lopez_Aliaga = "RLA", Nieto = "NTO",
           Belmont = "BLM", Sanchez = "RSP")

# Continent ubigeo codes (from ONPE API)
CONTINENTS <- data.frame(
  ubigeo = c("910000", "920000", "930000", "940000", "950000"),
  nombre = c("AFRICA", "AMERICA", "ASIA", "EUROPA", "OCEANIA"),
  stringsAsFactors = FALSE
)

# --- HTTP helper --------------------------------------------------------------

safe_GET <- function(url, params, retries = 2) {
  for (i in seq_len(retries)) {
    resp <- tryCatch(
      GET(url, query = params, timeout(15),
          add_headers(
            `User-Agent` = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36",
            `Referer`    = "https://resultadoelectoral.onpe.gob.pe/main/presidenciales",
            `Accept`     = "application/json"
          )
      ),
      error = function(e) NULL
    )
    if (!is.null(resp) && status_code(resp) == 200) {
      txt <- content(resp, as = "text", encoding = "UTF-8")
      if (startsWith(trimws(txt), "{")) return(txt)
    }
    Sys.sleep(i * 2)
  }
  return(NA_character_)
}

# ==============================================================================
# PART A: FETCH EXTRANJERO DATA BY CONTINENT
# ==============================================================================

msg(paste(rep("=", 70), collapse = ""))
msg("  FETCHING EXTRANJERO DATA BY CONTINENT")
msg(paste(rep("=", 70), collapse = ""))

# Rationale: extranjero uses idAmbitoGeografico=2. Each continent is a
# "department" within that scope, queried via tipoFiltro=ubigeo_nivel_01.
# We try idAmbitoGeografico=2 first; if that fails we try other values.

fetch_continent <- function(ubigeo, amb_id = 2) {
  
  # Actas
  actas_json <- safe_GET(ACTAS_EP, list(
    idAmbitoGeografico   = amb_id,
    idEleccion           = 10,
    tipoFiltro           = "ubigeo_nivel_01",
    idUbigeoDepartamento = ubigeo
  ))
  
  actas_data <- NULL
  if (!is.na(actas_json)) {
    parsed <- fromJSON(actas_json)
    if (parsed$success) actas_data <- parsed$data
  }
  
  # Votes
  votes_json <- safe_GET(VOTES_EP, list(
    tipoFiltro         = "ubigeo_nivel_01",
    idAmbitoGeografico = amb_id,
    ubigeoNivel1       = ubigeo,
    idEleccion         = 10
  ))
  
  votes_data <- NULL
  if (!is.na(votes_json)) {
    parsed <- fromJSON(votes_json)
    if (parsed$success && length(parsed$data) > 0) votes_data <- parsed$data
  }
  
  return(list(actas = actas_data, votes = votes_data))
}

# Try fetching each continent
continent_results <- list()

for (i in seq_len(nrow(CONTINENTS))) {
  ub <- CONTINENTS$ubigeo[i]
  nm <- CONTINENTS$nombre[i]
  msg(sprintf("\n  Fetching %s (%s)...", nm, ub))
  
  res <- fetch_continent(ub, amb_id = 2)
  
  # If amb_id=2 didn't work, try 3
  if (is.null(res$actas) && is.null(res$votes)) {
    msg("    amb_id=2 failed, trying amb_id=3...")
    res <- fetch_continent(ub, amb_id = 3)
  }
  
  row <- data.frame(
    continent    = nm,
    ubigeo       = ub,
    pct_actas    = NA_real_,
    total_actas  = NA_integer_,
    contabilizadas = NA_integer_,
    total_valid_counted = NA_real_,
    stringsAsFactors = FALSE
  )
  for (c in candidates) {
    row[[paste0("votos_", c)]] <- NA_integer_
    row[[paste0("pct_", c)]]   <- NA_real_
  }
  
  if (!is.null(res$actas)) {
    row$pct_actas    <- res$actas$actasContabilizadas
    row$total_actas  <- res$actas$totalActas
    row$contabilizadas <- res$actas$contabilizadas
    row$total_valid_counted <- res$actas$totalVotosValidos
    msg(sprintf("    Actas: %.3f%% (%d / %d)",
                    row$pct_actas, row$contabilizadas, row$total_actas))
  } else {
    msg("    No actas data")
  }
  
  if (!is.null(res$votes)) {
    for (c in candidates) {
      match <- res$votes[res$votes$nombreCandidato == CAND_FULLNAMES[c], ]
      if (nrow(match) == 1) {
        row[[paste0("votos_", c)]] <- match$totalVotosValidos
        row[[paste0("pct_", c)]]   <- match$porcentajeVotosValidos
      }
    }
    msg(sprintf("    Votes found for %d candidates",
                    sum(!is.na(row[paste0("votos_", candidates)]))))
  } else {
    msg("    No votes data")
  }
  
  continent_results[[i]] <- row
}

ext_df <- do.call(rbind, continent_results)

msg("\n--- Continent summary ---")
for (i in seq_len(nrow(ext_df))) {
  msg(sprintf("  %-10s  pct_actas: %6s%%  total_actas: %s",
                  ext_df$continent[i],
                  ifelse(is.na(ext_df$pct_actas[i]), "  NA", sprintf("%6.2f", ext_df$pct_actas[i])),
                  ifelse(is.na(ext_df$total_actas[i]), "NA", ext_df$total_actas[i])))
}

# --- Impute continents with no data from average of those with data -----------
# Rationale: Africa (or any continent with 0 actas) needs imputation.
# We use the average candidate shares and votes-per-acta from all continents
# that DO have data.

has_data <- ext_df$pct_actas > 0 & !is.na(ext_df$pct_actas)
no_data  <- !has_data | is.na(ext_df$pct_actas)

if (any(has_data)) {
  # Average votes per acta across continents with data
  total_valid_ext <- sum(ext_df$total_valid_counted[has_data], na.rm = TRUE)
  total_actas_counted_ext <- sum(ext_df$contabilizadas[has_data], na.rm = TRUE)
  avg_vpa <- total_valid_ext / total_actas_counted_ext
  
  # Average candidate shares
  total_cand_ext <- sapply(candidates, function(c)
    sum(ext_df[[paste0("votos_", c)]][has_data], na.rm = TRUE))
  sum_cand_ext <- sum(total_cand_ext)
  avg_shares <- total_cand_ext / sum_cand_ext
  
  msg(sprintf("\n  Average votes per acta (extranjero): %.1f", avg_vpa))
  msg("  Average candidate shares for imputation:")
  for (c in candidates) {
    msg(sprintf("    %-15s: %.2f%%", labels[c], avg_shares[c] * 100))
  }
}

# Extrapolate each continent
for (c in candidates) ext_df[[paste0("extrap_", c)]] <- 0
ext_df$method <- ""

for (i in seq_len(nrow(ext_df))) {
  pct <- ext_df$pct_actas[i]
  ta  <- ext_df$total_actas[i]
  if (is.na(ta)) ta <- 0
  
  if (!is.na(pct) && pct > 0) {
    # Direct extrapolation
    for (c in candidates) {
      v <- ext_df[[paste0("votos_", c)]][i]
      if (is.na(v)) v <- 0
      ext_df[[paste0("extrap_", c)]][i] <- v * (100 / pct)
    }
    ext_df$method[i] <- "direct"
    
  } else if (ta > 0 && any(has_data)) {
    # Impute from average of other continents
    est_valid <- avg_vpa * ta
    for (c in candidates) {
      ext_df[[paste0("extrap_", c)]][i] <- est_valid * avg_shares[c]
    }
    ext_df$method[i] <- "imputed_avg_continents"
    
  } else {
    ext_df$method[i] <- "skipped"
  }
}

msg("\n--- Extranjero extrapolated ---")
for (i in seq_len(nrow(ext_df))) {
  msg(sprintf("  %-10s [%s]  FUJ:%7s  RLA:%7s  NTO:%7s  BLM:%7s  RSP:%7s",
                  ext_df$continent[i], ext_df$method[i],
                  format(round(ext_df$extrap_Fujimori[i]), big.mark = ","),
                  format(round(ext_df$extrap_Lopez_Aliaga[i]), big.mark = ","),
                  format(round(ext_df$extrap_Nieto[i]), big.mark = ","),
                  format(round(ext_df$extrap_Belmont[i]), big.mark = ","),
                  format(round(ext_df$extrap_Sanchez[i]), big.mark = ",")))
}

ext_totals <- sapply(candidates, function(c)
  sum(ext_df[[paste0("extrap_", c)]], na.rm = TRUE))

msg("\n  EXTRANJERO TOTAL:")
for (c in candidates[order(-ext_totals)]) {
  msg(sprintf("    %-45s %10s",
                  labels[c], format(round(ext_totals[c]), big.mark = ",")))
}

# Total valid extranjero (all candidates)
ext_total_valid <- 0
for (i in seq_len(nrow(ext_df))) {
  pct <- ext_df$pct_actas[i]
  ta  <- ext_df$total_actas[i]
  tvc <- ext_df$total_valid_counted[i]
  if (!is.na(pct) && pct > 0 && !is.na(tvc)) {
    ext_total_valid <- ext_total_valid + tvc * (100 / pct)
  } else if (!is.na(ta) && ta > 0 && exists("avg_vpa")) {
    ext_total_valid <- ext_total_valid + avg_vpa * ta
  }
}

# ==============================================================================
# PART B: DOMESTIC DISTRICT EXTRAPOLATION
# ==============================================================================

msg("\n", paste(rep("=", 70), collapse = ""))
msg("  DOMESTIC DISTRICT EXTRAPOLATION")
msg(paste(rep("=", 70), collapse = ""))

df <- read_csv(
  "onpe_2026_district_results_04132026_2323.csv",
  col_types = cols(.default = "c")
)

num_cols <- c("pct_actas","actas_contabilizadas","total_actas",
              "votos_Fujimori","pct_Fujimori",
              "votos_Lopez_Aliaga","pct_Lopez_Aliaga",
              "votos_Nieto","pct_Nieto",
              "votos_Belmont","pct_Belmont",
              "votos_Sanchez","pct_Sanchez")
for (col in num_cols) {
  if (col %in% names(df)) df[[col]] <- as.numeric(df[[col]])
}
df$pct_actas[is.na(df$pct_actas)] <- 0

msg("Loaded ", nrow(df), " districts")
msg("  With data:  ", sum(df$pct_actas > 0))
msg("  Zero actas: ", sum(df$pct_actas == 0))

# Flag big-city districts
df$is_big_city <- FALSE
for (prov in unique(df$prov_code)) {
  idx <- which(df$prov_code == prov & df$pct_actas > 0)
  if (length(idx) >= 4) {
    threshold <- quantile(df$total_actas[idx], 0.75, na.rm = TRUE)
    df$is_big_city[idx[df$total_actas[idx] >= threshold]] <- TRUE
  } else if (length(idx) >= 2) {
    df$is_big_city[idx[which.max(df$total_actas[idx])]] <- TRUE
  }
}
msg("Big-city districts excluded from imputation: ", sum(df$is_big_city))

# Estimate valid votes per district
estimate_valid <- function(v, p) {
  ifelse(!is.na(p) & p > 0 & !is.na(v), v / (p / 100), 0)
}
df$est_valid <- estimate_valid(df$votos_Fujimori, df$pct_Fujimori)

# Province rates (excl big cities)
impute_pool <- df[df$pct_actas > 0 & !df$is_big_city, ]

prov_rates <- list()
for (prov in unique(impute_pool$prov_code)) {
  sub <- impute_pool[impute_pool$prov_code == prov, ]
  tv <- sum(sub$est_valid, na.rm = TRUE)
  ta <- sum(sub$actas_contabilizadas, na.rm = TRUE)
  cv <- sapply(candidates, function(c) sum(sub[[paste0("votos_", c)]], na.rm = TRUE))
  tc <- sum(cv)
  if (ta > 0 && tc > 0) prov_rates[[prov]] <- list(vpa = tv / ta, shares = cv / tc)
}

# Department rates (excl big cities)
dept_rates <- list()
for (dept in unique(impute_pool$dept_code)) {
  sub <- impute_pool[impute_pool$dept_code == dept, ]
  tv <- sum(sub$est_valid, na.rm = TRUE)
  ta <- sum(sub$actas_contabilizadas, na.rm = TRUE)
  cv <- sapply(candidates, function(c) sum(sub[[paste0("votos_", c)]], na.rm = TRUE))
  tc <- sum(cv)
  if (ta > 0 && tc > 0) dept_rates[[dept]] <- list(vpa = tv / ta, shares = cv / tc)
}

msg("Provinces with rates: ", length(prov_rates))
msg("Departments with rates: ", length(dept_rates))

# Extrapolate
for (c in candidates) df[[paste0("extrap_", c)]] <- 0
df$method <- ""
counts <- c(direct = 0, province = 0, department = 0, skipped = 0)

for (i in seq_len(nrow(df))) {
  pct  <- df$pct_actas[i]
  prov <- df$prov_code[i]
  dept <- df$dept_code[i]
  ta   <- df$total_actas[i]; if (is.na(ta)) ta <- 0
  
  if (!is.na(pct) && pct > 0) {
    for (c in candidates) {
      v <- df[[paste0("votos_", c)]][i]; if (is.na(v)) v <- 0
      df[[paste0("extrap_", c)]][i] <- v * (100 / pct)
    }
    df$method[i] <- "direct"; counts["direct"] <- counts["direct"] + 1
    
  } else if (ta > 0 && prov %in% names(prov_rates)) {
    ev <- prov_rates[[prov]]$vpa * ta
    for (c in candidates) df[[paste0("extrap_", c)]][i] <- ev * prov_rates[[prov]]$shares[c]
    df$method[i] <- "province"; counts["province"] <- counts["province"] + 1
    
  } else if (ta > 0 && dept %in% names(dept_rates)) {
    ev <- dept_rates[[dept]]$vpa * ta
    for (c in candidates) df[[paste0("extrap_", c)]][i] <- ev * dept_rates[[dept]]$shares[c]
    df$method[i] <- "department"; counts["department"] <- counts["department"] + 1
    
  } else {
    df$method[i] <- "skipped"; counts["skipped"] <- counts["skipped"] + 1
  }
}

msg("\n  Direct:     ", counts["direct"])
msg("  Province:   ", counts["province"])
msg("  Department: ", counts["department"])
msg("  Skipped:    ", counts["skipped"])

# ==============================================================================
# PART C: COMBINE DOMESTIC + EXTRANJERO
# ==============================================================================

dom_totals <- sapply(candidates, function(c)
  sum(df[[paste0("extrap_", c)]], na.rm = TRUE))

national <- dom_totals + ext_totals

# Total valid (all candidates)
total_valid_domestic <- 0
for (dept in unique(df$dept_code)) {
  sub <- df[df$dept_code == dept, ]
  sub_d <- sub[sub$pct_actas > 0, ]
  if (nrow(sub_d) > 0) {
    cv <- sum(sub_d$est_valid, na.rm = TRUE)
    ca <- sum(sub_d$actas_contabilizadas, na.rm = TRUE)
    ta <- sum(sub$total_actas, na.rm = TRUE)
    if (ca > 0) total_valid_domestic <- total_valid_domestic + cv * (ta / ca)
  }
}
total_valid <- total_valid_domestic + ext_total_valid
pct_national <- national / total_valid * 100
sorted_cands <- candidates[order(-national)]

