# --- Fetch functions ----------------------------------------------------------

fetch_country <- function(continent_ubigeo, country_ubigeo, amb_id = 2) {
  actas_json <- safe_GET(ACTAS_EP, list(
    idAmbitoGeografico = amb_id, idEleccion = 10, tipoFiltro = "ubigeo_nivel_02",
    idUbigeoDepartamento = continent_ubigeo, idUbigeoProvincia = country_ubigeo
  ))
  actas_data <- NULL
  if (!is.na(actas_json)) {
    parsed <- fromJSON(actas_json)
    if (parsed$success) actas_data <- parsed$data
  }
  
  votes_json <- safe_GET(VOTES_EP, list(
    tipoFiltro = "ubigeo_nivel_02", idAmbitoGeografico = amb_id,
    ubigeoNivel1 = continent_ubigeo, ubigeoNivel2 = country_ubigeo, idEleccion = 10
  ))
  votes_data <- NULL
  if (!is.na(votes_json)) {
    parsed <- fromJSON(votes_json)
    if (parsed$success && length(parsed$data) > 0) votes_data <- parsed$data
  }
  
  return(list(actas = actas_data, votes = votes_data))
}

fetch_continent <- function(ubigeo, amb_id = 2) {
  actas_json <- safe_GET(ACTAS_EP, list(
    idAmbitoGeografico = amb_id, idEleccion = 10, tipoFiltro = "ubigeo_nivel_01",
    idUbigeoDepartamento = ubigeo
  ))
  actas_data <- NULL
  if (!is.na(actas_json)) {
    parsed <- fromJSON(actas_json)
    if (parsed$success) actas_data <- parsed$data
  }
  
  votes_json <- safe_GET(VOTES_EP, list(
    tipoFiltro = "ubigeo_nivel_01", idAmbitoGeografico = amb_id,
    ubigeoNivel1 = ubigeo, idEleccion = 10
  ))
  votes_data <- NULL
  if (!is.na(votes_json)) {
    parsed <- fromJSON(votes_json)
    if (parsed$success && length(parsed$data) > 0) votes_data <- parsed$data
  }
  
  return(list(actas = actas_data, votes = votes_data))
}

parse_result <- function(res, region_name, region_ubigeo, continent_name) {
  row <- data.frame(
    region = region_name, ubigeo = region_ubigeo, continent = continent_name,
    pct_actas = NA_real_, total_actas = NA_integer_,
    contabilizadas = NA_integer_, total_valid_counted = NA_real_,
    stringsAsFactors = FALSE
  )
  for (c in candidates) {
    row[[paste0("votos_", c)]] <- NA_integer_
    row[[paste0("pct_", c)]]   <- NA_real_
  }
  if (!is.null(res$actas)) {
    row$pct_actas          <- res$actas$actasContabilizadas
    row$total_actas        <- res$actas$totalActas
    row$contabilizadas     <- res$actas$contabilizadas
    row$total_valid_counted <- res$actas$totalVotosValidos
  }
  if (!is.null(res$votes)) {
    for (c in candidates) {
      match_row <- res$votes[res$votes$nombreCandidato == CAND_FULLNAMES[c], ]
      if (nrow(match_row) == 1) {
        row[[paste0("votos_", c)]] <- match_row$totalVotosValidos
        row[[paste0("pct_", c)]]   <- match_row$porcentajeVotosValidos
      }
    }
  }
  return(row)
}

