# --- Impute zero-data units from continent average ----------------------------

compute_continent_avg <- function(sub_df) {
  has <- sub_df$pct_actas > 0 & !is.na(sub_df$pct_actas)
  if (!any(has)) return(NULL)
  tv <- sum(sub_df$total_valid_counted[has], na.rm = TRUE)
  ta <- sum(sub_df$contabilizadas[has], na.rm = TRUE)
  if (ta == 0) return(NULL)
  vpa <- tv / ta
  cv <- sapply(candidates, function(c)
    sum(sub_df[[paste0("votos_", c)]][has], na.rm = TRUE))
  tc <- sum(cv)
  if (tc == 0) return(NULL)
  return(list(vpa = vpa, shares = cv / tc))
}

continent_avgs <- list()
for (cont in unique(ext_df$continent)) {
  avg <- compute_continent_avg(ext_df[ext_df$continent == cont, ])
  if (!is.null(avg)) continent_avgs[[cont]] <- avg
}
global_avg <- compute_continent_avg(ext_df)

msg("\n--- Continent averages for imputation ---")
for (cont in names(continent_avgs)) {
